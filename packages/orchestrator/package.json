{
  "name": "@stina/orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "TSUP_DTS=false tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@stina/autonomy": "workspace:*",
    "@stina/core": "workspace:*",
    "@stina/extension-api": "workspace:*",
    "@stina/memory": "workspace:*",
    "@stina/threads": "workspace:*",
    "nanoid": "^5.0.0"
  },
  "devDependencies": {
    "@stina/shared": "workspace:*",
    "better-sqlite3": "^12.6.2",
    "@types/better-sqlite3": "^7.6.0",
    "drizzle-orm": "^0.36.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
