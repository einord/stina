{
    "name": "@stina/web",
    "version": "0.5.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vue-tsc --noEmit && vite build",
        "preview": "vite preview",
        "typecheck": "vue-tsc --noEmit && tsc --noEmit -p e2e/tsconfig.json",
        "e2e": "STINA_E2E=true playwright test"
    },
    "dependencies": {
        "@stina/extension-api": "workspace:*",
        "@stina/extension-installer": "workspace:*",
        "@stina/i18n": "workspace:*",
        "@stina/shared": "workspace:*",
        "@stina/ui-vue": "workspace:*",
        "vue": "^3.4.0",
        "@stina/api-client": "workspace:*"
    },
    "devDependencies": {
        "@playwright/test": "^1.44.0",
        "@stina/adapters-node": "workspace:*",
        "@stina/auth": "workspace:*",
        "@stina/autonomy": "workspace:*",
        "@stina/chat": "workspace:*",
        "@stina/memory": "workspace:*",
        "@stina/scheduler": "workspace:*",
        "@stina/test-fixtures": "workspace:*",
        "@stina/threads": "workspace:*",
        "@vitejs/plugin-vue": "^5.0.0",
        "typescript": "^5.3.0",
        "vite": "^5.0.0",
        "vue-tsc": "^2.0.0"
    }
}
